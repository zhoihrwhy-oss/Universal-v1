-- Fungsi lokal untuk memasang aura merah
local function beriAuraMerah(modelTarget)
    if not modelTarget:FindFirstChild("DiabloAuraVisual") then
        local auraVisual = Instance.new("SelectionBox")
        auraVisual.Name = "DiabloAuraVisual"
        auraVisual.Color3 = Color3.fromRGB(255, 0, 0) -- Warna Merah Darah
        auraVisual.LineThickness = 0.05
        auraVisual.Adornee = modelTarget
        auraVisual.Parent = modelTarget
    end
end

-- Fungsi membersihkan semua aura yang terpasang
local function bersihkanSemuaAura()
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("SelectionBox") and v.Name == "DiabloAuraVisual" then
            v:Destroy()
        end
    end
end

Btn4.MouseButton1Click:Connect(function()
    auraActive = not auraActive
    if auraActive then
        playTween(Btn4, {BackgroundColor3 = Color3.fromRGB(120, 0, 0), TextColor3 = Color3.fromRGB(255, 255, 255)})
        Btn4.Text = "Blood Lock Aura: ON"
        
        -- Loop mendeteksi kita, NPC/Bot, dan Player lain secara realtime
        auraLoop = RunService.Heartbeat:Connect(function()
            -- 1. Aura untuk karakter kita sendiri
            if Player.Character then beriAuraMerah(Player.Character) end
            
            -- 2. Aura untuk Player Lain & NPC/Bot di Workspace
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Humanoid") then
                    local charModel = obj.Parent
                    if charModel and charModel:IsA("Model") then
                        beriAuraMerah(charModel)
                    end
                end
            end
        end)
    else
        playTween(Btn4, {BackgroundColor3 = Color3.fromRGB(30, 8, 8), TextColor3 = Color3.fromRGB(240, 200, 200)})
        Btn4.Text = "Blood Lock Aura: OFF"
        if auraLoop then auraLoop:Disconnect() end
        bersihkanSemuaAura()
    end
