local function color3ToHex(c)
    return string.format("#%02x%02x%02x",
        math.clamp(math.floor(c.R*255),0,255),
        math.clamp(math.floor(c.G*255),0,255),
        math.clamp(math.floor(c.B*255),0,255)
    )
end

