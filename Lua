local function LoadMainScript()
    -- Visual Circle FOV
    local FOVCircle = Drawing.new("Circle")
    FOVCircle.Thickness = 1.5
    FOVCircle.Filled = false
    FOVCircle.Color = Color3.fromRGB(255, 0, 0)
    FOVCircle.Transparency = 0.7
    FOVCircle.Visible = config.aimbotEnabled

    local function getClosestPlayer()
        local closestTarget = nil
        local shortestDistance = config.fovRadius

        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
                if onScreen then
                    local mousePos = UserInputService:GetMouseLocation()
                    local distance = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if distance < shortestDistance then
                        closestTarget = player
                        shortestDistance = distance
                    end
                end
            end
        end
        return closestTarget
    end

    local clickTimer = 0
    local spinAngle = 0
    local floatPart = nil

    RunService.RenderStepped:Connect(function(dt)
        local character = LocalPlayer.Character
        if not character then return end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        
        FOVCircle.Radius = config.fovRadius
        FOVCircle.Position = UserInputService:GetMouseLocation()
        
        if config.aimbotEnabled then
            local target = getClosestPlayer()
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                local targetPos = target.Character.HumanoidRootPart.Position
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
            end
        end
        
        if humanoid then
            humanoid.WalkSpeed = config.walkSpeed
            if humanoid.UseJumpPower then
                humanoid.JumpPower = config.jumpPower
            else
                humanoid.JumpHeight = config.jumpPower / 3.5
            end
        end
        
        if rootPart and config.spinSpeed > 0 then
            spinAngle = (spinAngle + config.spinSpeed * dt * 10) % 360
            rootPart.CFrame = CFrame.new(rootPart.Position) * CFrame.Angles(0, math.deg(spinAngle), 0)
        end
        
        if config.autoClick then
            clickTimer = clickTimer + dt
            local delayThreshold = 1 / math.clamp(config.clickDelay, 1, 3)
            if clickTimer >= delayThreshold then
                clickTimer = 0
                local tool = character:FindFirstChildOfClass("Tool")
                if tool then
                    tool:Activate()
                end
            end
        end
        
        if config.fastAttack then
            local tool = character:FindFirstChildOfClass("Tool")
            if tool and tool:FindFirstChild("Animation") then
                for _, state in ipairs(humanoid:GetPlayingAnimationTracks()) do
                    if state.Animation.AnimationId == tool.Animation.AnimationId then
                        state:AdjustSpeed(100)
                    end
                end
            end
        end
        
        if config.floatingBlock and rootPart then
            if not floatPart or not floatPart.Parent then
                floatPart = Instance.new("Part")
                floatPart.Size = Vector3.new(6, 0.5, 6)
                floatPart.Transparency = 0.5
                floatPart.Color = Color3.fromRGB(130, 20, 180)
                floatPart.Material = Enum.Material.ForceField
                floatPart.Anchored = true
                floatPart.Parent = workspace
            end
            floatPart.Position = rootPart.Position - Vector3.new(0, 3.25, 0)
        else
            if floatPart then
                floatPart:Destroy()
                floatPart = nil
            end
        end
    end)

    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == Enum.KeyCode.Space and config.infJump then
            local character = LocalPlayer.Character
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            if humanoid and rootPart then
                rootPart.Velocity = Vector3.new(rootPart.Velocity.X, config.jumpPower, rootPart.Velocity.Z)
            end
        end
    end)

    local Window = WindUI:CreateWindow({
        Title        = "Diablo Script Universal",
        Icon         = "rbxassetid://909097323",
        Author       = "By Admin Zhoihr",
        Folder       = configFolder,
        Size         = UDim2.fromOffset(580, 440),
        Transparent  = false,
        NewElements  = true,
        Resizable    = true,
        User = {
            Enabled   = true,
            Anonymous = false,
        },
        Topbar = {
            ButtonsType = "Mac",
        }
    })

    local TabAim     = Window:Tab({ Title = "Menu 1 aim", Icon = "crosshair" })
    local TabXexx    = Window:Tab({ Title = "Menu 2 xexx", Icon = "zap" })
    local TabConfig  = Window:Tab({ Title = "Config", Icon = "database" })

    TabAim:Section({ Title = "Aim Bot Engine" })
    TabAim:Toggle({
        Title = "Circle Aim Bot",
        Value = config.aimbotEnabled,
        Callback = function(val)
            config.aimbotEnabled = val
            FOVCircle.Visible = val
            saveConfig(config)
        end
    })
    TabAim:Slider({
        Title = "Setting Area Radius (FOV)",
        Min = 30, Max = 800,
        Value = config.fovRadius,
        Callback = function(val)
            config.fovRadius = val
            saveConfig(config)
        end
    })
    TabAim:Section({ Title = "Position Utilities" })
    TabAim:Toggle({
        Title = "Floating System Below",
        Value = config.floatingBlock,
        Callback = function(val)
            config.floatingBlock = val
            saveConfig(config)
        end
    })
    TabAim:Toggle({
        Title = "Infinite Jump",
        Value = config.infJump,
        Callback = function(val)
            config.infJump = val
            saveConfig(config)
        end
    })

    TabXexx:Section({ Title = "Physical Attributes Modification" })
    TabXexx:Slider({
        Title = "Speed Walk Control",
        Min = 1, Max = 1000,
        Value = config.walkSpeed,
        Callback = function(val)
            config.walkSpeed = val
            saveConfig(config)
        end
    })
    TabXexx:Slider({
        Title = "Jump Power Multiplier",
        Min = 1, Max = 1000,
        Value = config.jumpPower,
        Callback = function(val)
            config.jumpPower = val
            saveConfig(config)
        end
    })
    TabXexx:Slider({
        Title = "Spin Character Velocity",
        Min = 0, Max = 1000,
        Value = config.spinSpeed,
        Callback = function(val)
            config.spinSpeed = val
            saveConfig(config)
        end
    })
    TabXexx:Section({ Title = "Combat Acceleration Tools" })
    TabXexx:Toggle({
        Title = "Auto Clicker Loop",
        Value = config.autoClick,
        Callback = function(val)
            config.autoClick = val
            saveConfig(config)
        end
    })
    TabXexx:Slider({
        Title = "Auto Click Spam Speed Rate",
        Min = 1, Max = 3,
        Value = config.clickDelay,
        Callback = function(val)
            config.clickDelay = val
            saveConfig(config)
        end
    })
    TabXexx:Toggle({
        Title = "Fast Attack Mode (No Cooldown Tools)",
        Value = config.fastAttack,
        Callback = function(val)
            config.fastAttack = val
            saveConfig(config)
        end
    })

    local SodiumConfig = Window.ConfigManager:Config("DiabloHubConfig")
    TabConfig:Section({ Title = "Profile Visual Configurations" })
    TabConfig:Dropdown({
        Title = "Interface Core Theme",
        Multi = false,
        Options = {"Dark", "Light", "Midnight", "Indigo", "Crimson"},
        Default = config.theme,
        Callback = function(selectedTheme)
            config.theme = selectedTheme
            saveConfig(config)
        end
    })

    WindUI:Notify({
        Title = "Diablo Universal Initialized",
        Content = "Successfully operational under WindUI framework.",
        Icon = "check-circle",
        Duration = 4
    })
end

